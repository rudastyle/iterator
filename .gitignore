# This .gitignore file should be placed at the root of your Unity project directory
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore

[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Mm]emoryCaptures/
UserSettings/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta
!/[Pp]ackages/**/*.meta

# Visual Studio / MonoDevelop generated files
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.pidb.meta

# Unity generated files
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.unitypackage

# Autogenerated VS/MD solution and project files
ExportedObj/
.consulo/
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta

# Compiled object files
*.obj
*.elf
*.exe
*.dll
*.lib
*.so
*.dylib
*.ncb
*.sdf
*.suo
*.pdb
*.idb
*.class
*.psdmeta

# Crash logs
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage

# User-specific files
*.pidb
*.user
*.userprefs
*.userosscache
*.sln.docstates

# Unity cache server
[Ee]xportPipelineCache/

# Memory capture files
*.mem

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta
!/[Pp]ackages/**/*.meta

# Uncomment if you have a code coverage folder
# coverage

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Windows image file caches
Thumbs.db
ehthumbs.db

# Visual Studio
.vs/

# Rider
.idea/
*.sln.iml

# JetBrains Rider and IntelliJ cache
*.iws
*.ipr
*.iml

# Package directories
[Pp]ackages/manifest.json

# Temporary files
*.tmp
*.bak
*.orig
*.swp
*~

# Unity generated folders
MemoryCaptures/

# Never ignore assets and packages meta files
!/[Aa]ssets/**/*.meta
!/[Pp]ackages/**/*.meta
